%% GPU-initiated KV Retrieve data flow — RADOS-backed NVMe Key Value namespace.
%% Mirrors the block diagram up to the controller; KV-specific nodes are highlighted.
flowchart TB
  subgraph GPU["AMD GPU — gfx1151 (guest)"]
    direction TB
    K["__device__ kernel · kvSqeSetup()<br/>packs KV Retrieve into 64-byte SQE<br/>opcode 0x02 · key inline (CDW2/3, CDW14/15)<br/>value buffer described by PRP → VRAM"]
    DB(["ring doorbell<br/>(MMIO write)"])
    VRAM[("GPU VRAM<br/>value buffer<br/>(P2PDMA target)")]
    CQ["poll CQ · completion + phase bit<br/>stored length in DW0"]
  end

  subgraph GRAM["Guest RAM"]
    SQ["shadow SQ ring<br/>64-byte KV SQE"]
  end

  subgraph QEMU["QEMU"]
    BR["pci-mmio-bridge device<br/>forward MMIO → NVMe BAR<br/>address_space_write()"]
  end

  subgraph SPDK["SPDK target (host)"]
    CTRL["vfio-user NVMe controller model<br/>CSI = Key Value (0x1)"]
    KVDEV["rados-nkv kvdev<br/>kvdev_rados: key → object"]
    LR["librados"]
  end

  subgraph CEPH["Ceph cluster"]
    OBJ[("RADOS object<br/>named by key<br/>content-addressed")]
  end

  K -->|enqueue SQE| SQ
  K --> DB
  DB --> BR
  SQ -. fetched by .-> CTRL
  BR --> CTRL
  CTRL --> KVDEV --> LR --> OBJ
  OBJ -. value .-> LR -. value .-> KVDEV
  KVDEV ==>|"SPDK P2PDMA into VRAM<br/>--memory-mode 8 · no host bounce"| VRAM
  CTRL -->|post completion| CQ
  CQ -. GPU reaps .-> K

  classDef kv fill:#fde8dc,stroke:#c2410c,stroke-width:2px,color:#7c2d12;
  classDef data fill:#eef6ff,stroke:#2563eb,color:#1e3a8a;
  class K,KVDEV,OBJ kv;
  class VRAM data;
